# Copy this file to Database/.env and fill in real values.
# Database/.env is gitignored — never commit your actual keys.

# Used by backup.sh and restore.sh
SUPABASE_URL=postgresql://postgres:your-password@your-project.supabase.co:5432/postgres
BACKUP_ENCRYPTION_KEY=your-gpg-passphrase

# Used by restore.sh only — the database you're restoring INTO
DB_URL=postgresql://postgres:your-password@localhost:5432/restore_test
